{
    "compilerOptions": {
        "target": "ES5",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "outDir": "../dist",
        "strict": true,
        "esModuleInterop": true,
        "allowJs": true,
        "sourceMap": false,
        "skipLibCheck": true,
        "lib": ["ES2015"],
        "typeRoots": ["node_modules/@types", "../types"]
    },
    "include": ["./**/*.ts", "../types/**/*.d.ts"]
}
